{
  "authMode": "trusted-publishing",
  "trustedPublisher": {
    "owner": "Botfather",
    "repository": "units",
    "repositoryUrl": "git+https://github.com/Botfather/units.git",
    "workflow": "publish.yml",
    "branch": "main",
    "allowedAction": "npm publish"
  },
  "packageScope": "@botfather",
  "verifyOidcExchange": true,
  "publishAllowedPackages": [
    "@botfather/units",
    "@botfather/units-tools",
    "@botfather/vite-plugin-units",
    "@botfather/units-slack-block-kit",
    "@botfather/vite-plugin-units-tools"
  ]
}
