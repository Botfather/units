{
  "name": "units-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Botfather/units.git"
  },
  "homepage": "https://botfather.github.io/units/",
  "bugs": {
    "url": "https://github.com/Botfather/units/issues"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "bench:parser": "node ./bench.js",
    "bench:dsl": "node ./tools/dsl-bench.mjs --config ./bench/dsl-bench.config.json --out ./bench/results/dsl-bench.json --report ./bench/results/dsl-bench.md",
    "bench:dsl:quick": "node ./tools/dsl-bench.mjs --config ./bench/dsl-bench.config.json --quick --out ./bench/results/dsl-bench-quick.json --report ./bench/results/dsl-bench-quick.md",
    "bench:system:plan": "node ./tools/system-bench.mjs plan --config ./bench/system-bench.config.json --out ./bench/results/system-bench-plan.json --report ./bench/results/system-bench-plan.md",
    "bench:system:run": "node ./tools/system-bench.mjs run --config ./bench/system-bench.config.json --out ./bench/results/system-bench.json --report ./bench/results/system-bench.md",
    "bench:llm": "node ./tools/llm-bench.mjs --mode offline --cases ./bench/llm-cases.json --out ./bench/results/llm-bench.json --report ./bench/results/llm-bench.md",
    "bench:llm:live": "node ./tools/llm-bench.mjs --mode live --cases ./bench/llm-cases.json --models ${LLM_BENCH_MODELS:-gpt-4.1-mini,gpt-4o-mini} --runs 1 --repair-attempts 2 --min-parse-ok-pct 90 --min-required-pct 80 --out ./bench/results/llm-bench-live.json --report ./bench/results/llm-bench-live.md",
    "bench:react-vs-dsl": "node ./tools/react-vs-dsl-bench.mjs --pairs ./bench/react-vs-dsl-pairs.json --out ./bench/results/react-vs-dsl.json --report ./bench/results/react-vs-dsl.md",
    "bench:react-vs-dsl:quick": "node ./tools/react-vs-dsl-bench.mjs --pairs ./bench/react-vs-dsl-pairs.json --synthetic-limit 60 --out ./bench/results/react-vs-dsl-quick.json --report ./bench/results/react-vs-dsl-quick.md",
    "bench:react-vs-dsl:provider": "node ./tools/react-vs-dsl-bench.mjs --pairs ./bench/react-vs-dsl-pairs.json --include-synthetic false --tokenizer-mode provider --provider-model gpt-4.1-mini --provider-min-positive-pct 70 --out ./bench/results/react-vs-dsl-provider.json --report ./bench/results/react-vs-dsl-provider.md",
    "bench:react-vs-dsl:provider:both": "node ./tools/react-vs-dsl-bench.mjs --pairs ./bench/react-vs-dsl-pairs.json --include-synthetic false --tokenizer-mode both --provider-model gpt-4.1-mini --provider-min-positive-pct 70 --out ./bench/results/react-vs-dsl-provider-both.json --report ./bench/results/react-vs-dsl-provider-both.md",
    "bench:react-vs-dsl:provider:optimized": "node ./tools/react-vs-dsl-bench.mjs --pairs ./bench/react-vs-dsl-pairs-optimized.json --include-synthetic false --tokenizer-mode both --provider-model gpt-4.1-mini --provider-min-positive-pct 100 --out ./bench/results/react-vs-dsl-provider-both-optimized.json --report ./bench/results/react-vs-dsl-provider-both-optimized.md",
    "bench:ui-ps": "node ./tools/ui-ps-bench.mjs --fixtures ./bench/ui-ps-fixtures.json --library ./bench/ui-ps-library --out ./bench/results/ui-ps-bench.json --report ./bench/results/ui-ps-bench.md",
    "bench:ui-ps:gate": "node ./tools/ui-ps-gate-check.mjs --result ./bench/results/ui-ps-bench.json --gates ./bench/ui-ps-gates.json",
    "test:units-agent-plugin": "node --test ./test/units-agent-plugin.test.mjs",
    "test:units-agent-service": "node --test ./test/units-agent-service.test.mjs",
    "test:units-incremental": "node --test ./test/units-incremental.test.mjs",
    "test:units-compiler": "node --test ./test/units-compiler.test.mjs",
    "test:units-tools-transform-verify": "node --test ./test/units-tools-transform-verify.test.mjs",
    "test:ui-ps-bench": "node --test ./test/ui-ps-bench.test.mjs",
    "test:ui-ps-gate-check": "node --test ./test/ui-ps-gate-check.test.mjs",
    "test:units-ui-ir": "node --test ./test/units-ui-ir.test.mjs",
    "test:units-react-adapter": "node --test ./test/units-react-adapter.test.mjs",
    "test:dsl-bench": "node --test ./test/dsl-bench.test.mjs",
    "test:vite-plugin-units-tools-agent": "node --test ./test/vite-plugin-units-tools-agent.test.mjs",
    "test:units-dom-snapshot": "node --test ./test/units-dom-snapshot.test.mjs",
    "test:units-transform": "node --test ./test/units-transform.test.mjs",
    "test:system-bench": "node --test ./test/system-bench.test.mjs",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status --verbose",
    "release": "changeset publish",
    "publish:dry": "pnpm -r --filter \"./packages/**\" publish --dry-run --access public --no-git-checks",
    "publish:ci": "pnpm -r --filter \"./packages/**\" publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7"
  }
}
