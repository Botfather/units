Grid(columns=@(layout.columns??3),gap=@(layout.gap??12),dense?=@(filters.enabled&&filters.mode!='none')){#for(card,index in @cards){#key(@card.id)Card(class=@(index%2==0?'featured':'compact'),score=@(metrics?.[card.id]?.score??0),visible?=@(permissions?.[card.id]!=false)){text '@{card.title} - @{metrics?.[card.id]?.score ?? 0}'Button(!click{openCard(@card.id,@(routes?.detail??'/detail'))}){@'Open'}}}}
