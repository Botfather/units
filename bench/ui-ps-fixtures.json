{
  "name": "ui-ps-fixtures-v2",
  "description": "Expanded host-tree fixtures with tricky structures and semantic-loss probes for UI compression quality.",
  "gates": {
    "action_recall": 1.0,
    "name_recall": 0.98,
    "text_f1": 0.95
  },
  "cases": [
    {
      "id": "dom_checkout_flow",
      "title": "Checkout form with hidden helper copy",
      "sourceType": "dom",
      "tags": ["baseline", "form"],
      "tree": {
        "tagName": "main",
        "id": "checkout-root",
        "children": [
          { "type": "text", "text": "Checkout" },
          {
            "tagName": "section",
            "attributes": { "aria-hidden": "true" },
            "children": [
              { "type": "text", "text": "Internal helper copy" }
            ]
          },
          {
            "tagName": "input",
            "attributes": {
              "type": "email",
              "aria-label": "Email address",
              "placeholder": "you@example.com"
            }
          },
          {
            "tagName": "button",
            "attributes": { "aria-label": "Pay now" },
            "textContent": "Pay now"
          }
        ]
      },
      "expectations": {
        "expectedActions": ["input", "click"],
        "expectedNames": ["Email address", "Pay now"],
        "expectedText": "Checkout Pay now"
      }
    },
